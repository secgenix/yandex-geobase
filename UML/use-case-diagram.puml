@startuml Use Case Diagram - Геобаза
!theme plain
skinparam backgroundColor #ffffff
skinparam classBackgroundColor #f0f0f0
skinparam classBorderColor #333333

actor Пользователь as User
actor Администратор as Admin
package "Система Геобаза" {
  usecase UC1 as "Просмотр интерактивной карты"
  usecase UC2 as "Поиск объектов по названию/адресу"
  usecase UC3 as "Фильтрация по категориям"
  usecase UC4 as "Фильтрация по статусу"
  usecase UC5 as "Фильтрация по городу"
  usecase UC6 as "Просмотр карточки объекта"
  usecase UC7 as "Центрирование карты на объекте"
  usecase UC8 as "Просмотр список объектов"
  usecase UC9 as "Добавление новых объектов"
  usecase UC10 as "Редактирование объектов"
  usecase UC11 as "Управление фильтрами"
  usecase UC12 as "Просмотр кластеров маркеров"
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6
User --> UC7
User --> UC8
User --> UC12

Admin --> UC9
Admin --> UC10
Admin --> UC11

UC2 ..> UC3 : include
UC2 ..> UC4 : include
UC2 ..> UC5 : include
UC6 ..> UC1 : extend
UC6 ..> UC8 : extend
UC8 --> UC7

@enduml
